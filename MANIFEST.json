{
  "version": "v9.12.0",
  "description": "kcommit-analysis-pipeline: analyze Linux kernel commits for security and performance relevance",
  "library_dir": "lib",
  "scoring_dir": "configs/scoring",
  "example_configs": [
    "configs/example-arm-embedded-full.json"
  ],
  "pipeline_stages": [
    {
      "index": 0,
      "key": "prepare_pipeline",
      "script": "00_prepare_pipeline.py",
      "outputs": [
        "cache/00_compiled_rules.json",
        "cache/00_prepare_summary.json"
      ]
    },
    {
      "index": 1,
      "key": "collect_commits",
      "script": "01_collect_commits.py",
      "outputs": [
        "cache/01_commits.json"
      ]
    },
    {
      "index": 2,
      "key": "collect_build_context",
      "script": "02_collect_build_context.py",
      "outputs": [
        "cache/02_build_context.json",
        "cache/02_kbuild_static_map.json"
      ]
    },
    {
      "index": 3,
      "key": "build_product_map",
      "script": "03_build_product_map.py",
      "outputs": [
        "cache/03_product_map.json"
      ]
    },
    {
      "index": 4,
      "key": "prefilter_commits",
      "script": "04_prefilter_commits.py",
      "outputs": [
        "cache/04_filtered_commits.json"
      ]
    },
    {
      "index": 5,
      "key": "score_commits",
      "script": "05_score_commits.py",
      "outputs": [
        "cache/05_scored_commits.json"
      ]
    },
    {
      "index": 6,
      "key": "postfilter_commits",
      "script": "06_postfilter_commits.py",
      "outputs": [
        "cache/06_relevant_commits.json"
      ]
    },
    {
      "index": 7,
      "key": "report_commits",
      "script": "07_report_commits.py",
      "outputs": [
        "output/relevant_commits.csv",
        "output/06_relevant_commits.json",
        "output/report_stats.json",
        "output/profile_summary.json",
        "output/profile_matrix.csv",
        "output/summary.html"
      ]
    }
  ],
  "tools": [
    "tools/generate_message_whitelist.py"
  ],
  "template_dir": "configs/templates"
}
