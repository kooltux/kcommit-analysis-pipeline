  "ftrace":       ["kernel/trace/"],
  "kprobes":      ["kernel/kprobes.c"],
  "audit":        ["kernel/audit.c", "kernel/auditsc.c"],
  "filesystems":  ["fs/"],
  "ext4":         ["fs/ext4/"],
  "btrfs":        ["fs/btrfs/"],
  "xfs":          ["fs/xfs/"],
  "vfs":          ["fs/"],
  "tty":          ["drivers/tty/"],
  "serial":       ["drivers/tty/serial/"],
