{
  "//": "Subsystem-keyword to kernel source path prefixes.",
  "//2": "Used by lib/scoring.infer_touched_paths() to guess relevant paths from a commit subject.",
  "//3": "Format: { \"keyword\": [\"path/prefix1/\", \"path/prefix2/\"] }",

  "net":          ["net/", "drivers/net/"],
  "network":      ["net/", "drivers/net/"],
  "tcp":          ["net/ipv4/", "net/ipv6/"],
  "udp":          ["net/ipv4/", "net/ipv6/"],
  "ipv6":         ["net/ipv6/"],
  "ipv4":         ["net/ipv4/"],
  "netfilter":    ["net/netfilter/"],
  "can":          ["drivers/net/can/"],
  "ethernet":     ["drivers/net/ethernet/"],
  "wifi":         ["drivers/net/wireless/"],
  "bluetooth":    ["net/bluetooth/", "drivers/bluetooth/"],
  "usb":          ["drivers/usb/"],
  "pci":          ["drivers/pci/"],
  "i2c":          ["drivers/i2c/"],
  "spi":          ["drivers/spi/"],
  "gpio":         ["drivers/gpio/", "include/linux/gpio/"],
  "pinctrl":      ["drivers/pinctrl/"],
  "pwm":          ["drivers/pwm/"],
  "regulator":    ["drivers/regulator/"],
  "mmc":          ["drivers/mmc/"],
  "sata":         ["drivers/ata/"],
  "nvme":         ["drivers/nvme/"],
  "block":        ["block/", "drivers/block/"],
  "crypto":       ["crypto/", "drivers/crypto/"],
  "cve":          ["security/"],
  "security":     ["security/"],
  "selinux":      ["security/selinux/"],
  "smack":        ["security/smack/"],
  "apparmor":     ["security/apparmor/"],
  "seccomp":      ["kernel/seccomp.c"],
