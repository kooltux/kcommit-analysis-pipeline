  "mm":           ["mm/"],
  "oom":          ["mm/oom_kill.c"],
  "slab":         ["mm/slab.c", "mm/slub.c"],
  "hugepages":    ["mm/hugetlb.c"],
  "numa":         ["mm/mempolicy.c"],
  "scheduler":    ["kernel/sched/"],
  "sched":        ["kernel/sched/"],
  "preempt":      ["kernel/sched/"],
