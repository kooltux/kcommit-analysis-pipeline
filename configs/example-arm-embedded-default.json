{
  "project": {
    "name": "arm-embedded-analysis",
    "work_dir": "${WORKSPACE}/work"
  },
  "kernel": {
    "source_dir": "${WORKSPACE}/linux",
    "rev_old": "v4.14.206",
    "rev_new": "v4.14.336",
    "kernel_config": "${WORKSPACE}/linux/.config",
    "build_dir": "${WORKSPACE}/build"
  },
  "inputs": {
    "kernel_build_log": "${WORKSPACE}/logs/kernel_build.log",
    "yocto_build_log": "${WORKSPACE}/logs/yocto_build.log",
    "dts_roots": [
      "${WORKSPACE}/linux/arch/arm/boot/dts"
    ],
    "profiles_dir": "${CONFIGDIR}/profiles",
    "rules_dir": "${CONFIGDIR}/rules",
    "scoring_dir": "${CONFIGDIR}/scoring",
    "templates_dir": "${CONFIGDIR}/templates"
  },
  "profiles": {
    "active": {
      "security_fixes": 100,
      "security_features": 80,
      "performance": 60
    }
  },
  "collect": {
    "use_numstat": true,
    "use_no_merges": true,
    "use_first_parent": false,
    "max_commits": 0,
    "score_workers": 0
  },
  "scoring": {
    "product": 1.0,
    "stable": 1.2,
    "symbol_match": 1.0
  },
  "vars": {
    "WORKSPACE": "${WORKSPACE}",
    "TOOLDIR": "${TOOLDIR}",
    "CONFIGDIR": "${CONFIGDIR}"
  },
  "templates": {
    "html_summary": true,
    "report_title": "ARM Embedded Analysis",
    "top_n": 200,
    "summary_css": "${CONFIGDIR}/templates/summary.css"
  }
}
