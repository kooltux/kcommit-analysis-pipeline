{
  // ─────────────────────────────────────────────────────────────────────────
  // kcommit-analysis-pipeline 
  // ─────────────────────────────────────────────────────────────────────────
  "vars": {
    // WORKSPACE is imported from the calling environment (export WORKSPACE=...)
    "WORKSPACE": "${WORKSPACE}",
    "TOOLDIR": "${TOOLDIR}",
    "CONFIGDIR": "${CONFIGDIR}",
    "kernel_src": "${WORKSPACE}/linux/",
    "build_dir": "${WORKSPACE}/build",
    "logs_dir": "${WORKSPACE}/logs"
  },
  "project": {
    "name": "arm-embedded-full",
    "work_dir": "${WORKSPACE}/work"
  },
  "kernel": {
    "source_dir": "${kernel_src}",
    "rev_old": "v4.14.206",
    "rev_new": "v4.14.336",
    // kernel_config and build_dir are OPTIONAL
    // When absent, Kconfig symbol mapping and artifact scanning are skipped.
    "kernel_config": "${build_dir}/.config",
    "build_dir": "${WORKSPACE}/build"
  },
  "inputs": {
    "kernel_build_log": "${logs_dir}/kernel_build.log",
    "yocto_build_log": "${logs_dir}/yocto_build.log",
    "dts_roots":        ["${kernel_src}/arch/arm/boot/dts"],
    "profiles_dir": "${CONFIGDIR}/profiles",
    "rules_dir": "${CONFIGDIR}/rules",
    "scoring_dir": "${CONFIGDIR}/scoring",
    "templates_dir": "${CONFIGDIR}/templates"
  },
  // ── Profiles ─────────────────────────────────────────────────────────────
  // Higher weight = larger contribution to the final score from that profile.
  "profiles": {
    "active": {
      "security_fixes": 100,
      "security_features": 90,
      "performance": 70
    }
  },
  "scoring": {
    "product": 1.0,
    "stable": 1.2,
    "symbol_match": 1.2
  },
  "collect": {
    "use_numstat": true,
    "use_no_merges": true,
    "use_first_parent": false,
    "max_commits": 0,
    "score_workers": 4,
    "jsonl": false
  },
  "history_mapping": {
    "mode": "sampled",
    "sample_step": 500,
    "max_commits_per_probe": 3
  },
  "templates": {
    "html_summary": true,
    "report_title": "ARM Embedded - Full Analysis",
    "top_n": 500,
    "summary_css": "${CONFIGDIR}/templates/summary.css"
  }
}
