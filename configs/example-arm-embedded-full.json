{
  // ─────────────────────────────────────────────────────────────────────────
  // kcommit-analysis-pipeline — ARM embedded full example config (v9.5)
  //
  // Variable expansion: ${VAR} is expanded in all string values.
  // Available variables:
  //   WORKSPACE  – external workspace root (from shell environment)
  //   TOOLDIR    – pipeline repository root (auto-set by the loader)
  //   CONFIGDIR  – directory containing this config file (auto-set)
  //   CWD        – current working directory
  // ─────────────────────────────────────────────────────────────────────────

  "vars": {
    // Import environment variables used in this file.
    // export WORKSPACE=/path/to/ws  TOOLDIR=/path/to/kcommit  CONFIGDIR=...
    "WORKSPACE": "${WORKSPACE}",
    "TOOLDIR":   "${TOOLDIR}",
    "CONFIGDIR": "${CONFIGDIR}",
    // User-defined shorthand variables for readability.
    "kernel_src": "${WORKSPACE}/linux",
    "build_dir":  "${WORKSPACE}/build",
    "logs_dir":   "${WORKSPACE}/logs"
  },

  "project": {
    "name":     "arm-embedded-full",
    // work_dir: where cache/ and output/ sub-directories are created.
    "work_dir": "${WORKSPACE}/work"
  },

  // ── Kernel source and build inputs ────────────────────────────────────────
  "kernel": {
    // Mandatory: path to the Linux kernel git repository.
    "source_dir": "${kernel_src}",

    // Mandatory: revision range to analyse (inclusive git refs).
    "rev_old":    "v4.14.206",
    "rev_new":    "v4.14.336",

    // Optional: .config file used for Kconfig-symbol-to-path mapping.
    // When absent, symbol mapping is skipped (no product-map CONFIG_ entries).
    "kernel_config": "${build_dir}/.config",

    // Optional: kernel build output directory for compiled-artifact scanning.
    "build_dir":     "${build_dir}",

    // Optional build logs — all three are optional; missing paths are skipped.
    // kernel_build_log: output of   make V=1 2>&1 | tee kernel_build.log
    // yocto_build_log:  output of a Yocto/OE bitbake run
    "kernel_build_log": "${logs_dir}/kernel_build.log",
    "yocto_build_log":  "${logs_dir}/yocto_build.log",

    // Optional: Device Tree Source root directories for product subsystem hints.
    "dts_roots": ["${kernel_src}/arch/arm/boot/dts"]
  },

  // ── Profiles ──────────────────────────────────────────────────────────────
  // profiles.active: map of profile-name → weight (0–100).
  // The weight scales the profile's rule contributions:
  //   100 = full contribution (multiplier 1.0)
  //    50 = half  contribution (multiplier 0.5)
  //     0 = profile disabled
  // List form also accepted: ["security_fixes", "performance"]
  "profiles": {
    "active": {
      "security_fixes":    100,
      "security_features":  90,
      "performance":        70
    }
    // Optional: override the default profiles directory.
    // Default: <CONFIGDIR>/profiles
    // "profiles_dir": "${CONFIGDIR}/profiles"
  },

  // ── Rules ─────────────────────────────────────────────────────────────────
  // Optional: override the default rules directory.
  // Default: <CONFIGDIR>/rules
  // Each sub-directory of rules_dir is one rule set; every rule set
  // may contain: keywords_whitelist.txt, keywords_blacklist.txt,
  //              path_whitelist.txt, path_blacklist.txt,
  //              commit_whitelist.txt, commit_blacklist.txt
  // "rules": { "rules_dir": "${CONFIGDIR}/rules" },

  // Commits that cannot possibly receive a non-zero score are dropped before
  "filter": {
    // enabled: set false to disable path/product filtering.
    // Rule 1 (SHA commit_blacklist) remains active even when enabled=false.
    "enabled": true,

    // path_blacklist_global: drop commits where EVERY touched file matches
    // the merged path_blacklist across all active profiles.
    // Example: a commit that only touches Documentation/ would be dropped
    // if Documentation/** is in a profile's path_blacklist.
    "path_blacklist_global": true,

    // require_kconfig_coverage: drop commits where no touched file is reachable
    // from any Kconfig symbol enabled in the kernel .config.
    //   null  = auto (enabled automatically when kbuild_static_map is available)
    //   true  = always enforce (pipeline fails if kbuild_static_map is missing)
    //   false = disabled
    "require_kconfig_coverage": null
  },

  // ── Commit collection (stage 01) ──────────────────────────────────────────
  "collect": {
    // use_numstat: attach per-file change stats (insertions/deletions).
    "use_numstat":       true,
    // use_no_merges: pass --no-merges to git log (recommended).
    "use_no_merges":     true,
    // use_first_parent: pass --first-parent to git log.
    "use_first_parent":  false,
    // max_commits: cap on commits collected (0 = no limit).
    "max_commits":       0,
    // score_workers: parallel workers for scoring (0 = auto-detect).
    "score_workers":     0,
    // jsonl: also write commits.jsonl for streaming consumers.
    "jsonl":             false,
    // include_parents: attach parent SHA list to each commit dict.
    "include_parents":   false
  },

  // ── History mapping (stage 03) ────────────────────────────────────────────
  // Controls how the config-symbol → source-file history map is built.
  "history_mapping": {
    // mode: range | sampled | full | disabled
    //   range    – walk commits between rev_old..rev_new (recommended)
    //   sampled  – sample every sample_step commits
    //   full     – walk the entire git log (slow)
    //   disabled – skip history mapping entirely
    "mode":                  "sampled",
    // sample_step: used when mode = "sampled"
    "sample_step":           500,
    "max_commits_per_probe": 3,
    // max_failure_rate: abort stage if git-show failure rate exceeds this fraction.
    "max_failure_rate":      0.05
  },

  // ── HTML report and output options ────────────────────────────────────────
  "templates": {
    // html_summary: generate output/summary.html.
    "html_summary":  true,
    // report_title: shown in HTML <title> and page header (analysis date appended).
    "report_title":  "ARM Embedded - Full Analysis",
    // top_n: maximum commits to display in the HTML table (sorted by score desc).
    "top_n":         5000,
    // css_override: path to a custom CSS file appended after the built-in styles.
    // Relative paths resolve from CONFIGDIR.
    "css_override":  "",
    // csv_output: generate output/relevant_commits.csv.
    "csv_output":    true,
    // xls_output: generate output/relevant_commits.xlsx (stdlib zipfile, no deps).
    "xls_output":    true,
    // ods_output: generate output/relevant_commits.ods.
    "ods_output":    true
  }
}
