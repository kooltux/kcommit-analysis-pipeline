// Comments are allowed: lines starting with // or # are ignored by the loader.
{
  "vars": {
    "TOOLDIR": "${TOOLDIR}",
    "WORKSPACE": "${WORKSPACE}",
    "kernel_src": "${WORKSPACE}/linux",
    "kernel_config": "${WORKSPACE}/kernel.config",
    "build_dir": "${WORKSPACE}/build",
    "logs_dir": "${WORKSPACE}/logs",
    "modules_list": "${WORKSPACE}/modules.txt"
  },
  "project": {
    "name": "example-arm-embedded-full",
    "work_dir": "${WORKSPACE}/work-example-arm-embedded-full"
  },
  "kernel": {
    "source_dir": "${kernel_src}",
    "rev_old": "v4.14.206",
    "rev_new": "v4.14.336"
  },
  "inputs": {
    "kernel_config": "${kernel_config}",
    "build_dir": "${build_dir}",
    "kernel_build_log": "${logs_dir}/kernel-build.log",
    "yocto_build_log": "${logs_dir}/yocto.log",
    "modules_file": "${modules_list}",
    "dts_roots": [
      "${kernel_src}/arch/arm/boot/dts"
    ]
  },
  "profiles": {
    "active": [
      "security_fixes",
      "security_features",
      "performance"
    ]
  },
  "templates": {
    "report_title": "Kernel commit analysis report",
    "html_summary": true,
    "top_n_commits": 50,
    "include_pipeline_stats": true
  },
  "collect": {
    "max_commits": 0,
    "jsonl": false
  }
}
