{
  // kcommit-analysis-pipeline v7.17 – ARM embedded example (all knobs)
  "vars": {
    "WORKSPACE": "${WORKSPACE}",
    "TOOLDIR":   "${TOOLDIR}"
  },
  "project": {
    "name":     "arm-embedded-full",
    "work_dir": "${WORKSPACE}/work"
  },
  "kernel": {
    "source_dir": "${WORKSPACE}/linux",
    "rev_old":    "v6.6",
    "rev_new":    "v6.9"
  },
  "inputs": {
    "kernel_config":    "${WORKSPACE}/linux/.config",
    "build_dir":        "${WORKSPACE}/build",
    "kernel_build_log": "${WORKSPACE}/logs/kernel_build.log",
    "yocto_build_log":  "${WORKSPACE}/logs/yocto_build.log",
    "dts_roots":        ["${WORKSPACE}/linux/arch/arm64/boot/dts"]
  },
  "profiles": {
    "dir": "${TOOLDIR}/configs/profiles",
    "active": {
      "security_fixes":    100,
      "security_features":  80,
      "performance":        60
    }
  },
  "rules": {
    "dir": "${TOOLDIR}/configs/rules"
  },
  "scoring": {
    "product":     1.0,
    "security":    2.0,
    "performance": 1.0,
    "stable":      1.5
  },
  "collect": {
    "use_numstat":      true,
    "use_no_merges":    true,
    "use_first_parent": false,
    "max_commits":      0,
    "score_workers":    4,
    "jsonl":            false
  },
  "history_mapping": {
    "mode":                  "sampled",
    "sample_step":           500,
    "max_commits_per_probe": 3
  },
  "templates": {
    "html_summary":  true,
    "report_title":  "ARM Embedded – Full Analysis",
    "top_n":         500,
    "summary_css":   "${TOOLDIR}/configs/templates/summary.css"
  }
}
