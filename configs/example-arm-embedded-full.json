{
  // ─────────────────────────────────────────────────────────────────────────
  // kcommit-analysis-pipeline — ARM embedded full example config
  //
  // Variable expansion: ${VAR} is expanded in all string values.
  // Available variables:
  //   WORKSPACE  – external workspace root (from shell environment)
  //   TOOLDIR    – pipeline repository root (auto-set by the loader)
  //   CONFIGDIR  – directory containing this config file (auto-set)
  //   CWD        – current working directory
  // ─────────────────────────────────────────────────────────────────────────

  "vars": {
    // Import environment variables used in this file.
    // export WORKSPACE=/path/to/ws  TOOLDIR=/path/to/kcommit  CONFIGDIR=...
    "WORKSPACE": "${WORKSPACE}",
    "TOOLDIR":   "${TOOLDIR}",
    "CONFIGDIR": "${CONFIGDIR}",
    // User-defined shorthand variables for readability.
    "kernel_src": "${WORKSPACE}/linux",
    "build_dir":  "${WORKSPACE}/build",
    "logs_dir":   "${WORKSPACE}/logs"
  },

  "paths": {
    "work_dir": "${WORKSPACE}/work"
    // Optional: override cache/output locations individually.
    // "cache_dir":  "${WORKSPACE}/work/cache",
    // "output_dir": "${WORKSPACE}/work/output",
    // Optional: override profile/rule search paths.
    // Profiles and rules are searched in order; names must be unique across all listed directories.
    // "profiles_dirs": ["${CONFIGDIR}/profiles", "/shared/team/profiles"],
    // "rules_dirs":    ["${CONFIGDIR}/rules", "/shared/team/rules"],
    // Optional: override HTML template directory.
    // "templates_dir": "${CONFIGDIR}/html"
  },

  // ── Kernel source and build inputs ────────────────────────────────────────
  "kernel": {
    // Mandatory: path to the Linux kernel git repository.
    "source_dir": "${kernel_src}",

    // Mandatory: revision range to analyse (inclusive git refs).
    "rev_old":    "v4.14.206",
    "rev_new":    "v4.14.336",

    // Optional: .config file used for Kconfig-symbol-to-path mapping.
    // When absent, symbol mapping is skipped (no product-map CONFIG_ entries).
    "kernel_config": "${build_dir}/.config",

    // Optional: kernel build output directory for compiled-artifact scanning.
    "build_dir":     "${build_dir}",

    // Optional build logs — all three are optional; missing paths are skipped.
    // kernel_build_log: output of   make V=1 2>&1 | tee kernel_build.log
    // yocto_build_log:  output of a Yocto/OE bitbake run
    "kernel_build_log": "${logs_dir}/kernel_build.log",
    "yocto_build_log":  "${logs_dir}/yocto_build.log",

    // Optional: Device Tree Source root directories for product subsystem hints.
    "dts_roots": ["${kernel_src}/arch/arm/boot/dts"]
  },

  // ── Profiles ──────────────────────────────────────────────────────────────
  // profiles.active: map of profile-name → weight (0–100).
  // The weight scales the profile's rule contributions:
  //   100 = full contribution (multiplier 1.0)
  //    50 = half  contribution (multiplier 0.5)
  //     0 = profile disabled
  "profiles": {
    "active": {
      "performance":        70,
      "security_fixes":    100,
      "security_features":  90
    }  },

  // ── Rules ─────────────────────────────────────────────────────────────────
  // Rule directories are configured via paths.rules_dirs.
  // Each sub-directory of a rules directory is one rule set; every rule set
  // may contain: keywords_whitelist.txt, keywords_blacklist.txt,
  //              path_whitelist.txt, path_blacklist.txt,
  //              commit_whitelist.txt, commit_blacklist.txt
  // Default search path when paths.rules_dirs is omitted: ${CONFIGDIR}/rules

  // Commits that cannot possibly receive a non-zero score are dropped before
  "filter": {
    // enabled: enable/disable path and product filtering.
    // Accepted: true | false. Default: true
    // Note: SHA-based commit_blacklist is always active regardless of this flag.
    "enabled": true,

    // path_blacklist_global: drop commits where EVERY touched file is blacklisted.
    // Accepted: true | false. Default: true
    // When true: a commit touching only Documentation/ is dropped if that path is blacklisted.
    "path_blacklist_global": true,

    // require_kconfig_coverage: drop commits where no touched file maps to an enabled CONFIG_*.
    // Accepted: null | true | false. Default: null
    //   null  = auto (active when kbuild_static_map is available)
    //   true  = always enforce (error if kbuild_static_map is missing)
    //   false = disabled
    "require_kconfig_coverage": null,

    // min_score: commits with a total score STRICTLY LOWER THAN this value
    // are dropped by stage 06 (postfilter_commits) before reports are produced.
    // Accepted: integer >= 0. Default: 0 (keep all scored commits).
    "min_score": 0
  },

  // ── Commit collection (stage 01) ──────────────────────────────────────────
  "collect": {
    // use_numstat: attach per-file change stats (insertions/deletions).
    "use_numstat":       true,
    // use_no_merges: pass --no-merges to git log (recommended).
    "no_merges":     true,
    // use_first_parent: pass --first-parent to git log.
    "first_parent":  false,
    // max_commits: cap on commits collected (0 = no limit).
    "max_commits":       0,
    // score_workers: parallel workers for scoring (0 = auto-detect).
    "score_workers":     0,
    // git_binary: override the git executable path (default: "git").
    // "git_binary":       "git",
    // use_name_only: pass --name-only to git log instead of --name-status.
    // "use_name_only":    false,
    // extra_git_log_args: raw extra args appended to git log (advanced).
    // "extra_git_log_args": [],
    // jsonl: also write commits.jsonl for streaming consumers.
    "jsonl":             false,
    // include_parents: attach parent SHA list to each commit dict.
    "include_parents":   false
  },

  // ── History mapping (stage 03) ────────────────────────────────────────────
  // Controls how the config-symbol → source-file history map is built.
  "history_mapping": {
    // mode: range | sampled | full | disabled
    //   range    – walk commits between rev_old..rev_new (recommended)
    //   sampled  – sample every sample_step commits
    //   full     – walk the entire git log (slow)
    //   disabled – skip history mapping entirely
    "mode":                  "range",
    // sample_step: used when mode = "sampled"
    "sample_step":           500,
    "max_commits_per_probe": 3,
    // max_failure_rate: abort stage if git-show failure rate exceeds this fraction.
    "max_failure_rate":      0.05
  },

  // ── Scoring ───────────────────────────────────────────────────────────────
  // Optional: override the scoring data directory.
  // Default: ${CONFIGDIR}/scoring
  // "scoring": { "scoring_dir": "${CONFIGDIR}/scoring" },

  // ── HTML report and output options ────────────────────────────────────────
  "reports": {
    // title: heading shown at the top of the HTML report.
    // Accepted: any string. Default: "kcommit Analysis Report"
    "title":   "ARM Embedded Analysis",

    // outputs: list of formats to produce.
    // Accepted values (any combination): "html", "csv", "xlsx", "ods"
    "outputs": ["html", "csv", "xlsx"],

    // top_n: maximum number of commits included in HTML/XLSX/ODS reports.
    // Accepted: integer > 0. Default: 5000
    "top_n":   500

    // css_override: optional extra stylesheet appended to the HTML report.
    // Useful for light branding or local presentation tweaks.
    // "css_override": "${CONFIGDIR}/html/local-overrides.css",

    // templates_dir is configured via paths.templates_dir when you need to
    // override the built-in HTML template directory.
  }
}
